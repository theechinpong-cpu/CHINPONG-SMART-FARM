    { q: "กล่องยาสีฟันกว้าง 3 cm ยาว 15 cm สูง 3 cm ปริมาตรเท่าใด", a: ["135 cm³", "45 cm³", "90 cm³", "21 cm³"], c: 0, e: "3 × 15 × 3 = 135" },
    { q: "หน่วยของปริมาตรคืออะไร", a: ["ตารางหน่วย", "หน่วย", "ลูกบาศก์หน่วย", "องศา"], c: 2, e: "ปริมาตรใช้หน่วยลูกบาศก์" },
    { q: "กระบะทรายกว้าง 1.5 m ยาว 2 m ลึก 0.5 m ปริมาตรทรายเต็มกระบะคือเท่าใด", a: ["1.5 m³", "3 m³", "0.75 m³", "6 m³"], c: 0, e: "1.5 × 2 × 0.5 = 1.5" },
    { q: "คอนกรีตหนึ่งแผ่นกว้าง 30 cm ยาว 30 cm หนา 5 cm ปริมาตรเท่าใด", a: ["450 cm³", "4,500 cm³", "900 cm³", "1,500 cm³"], c: 1, e: "30 × 30 × 5 = 4,500" },
    { q: "น้ำส้ม 500 ลูกบาศก์เซนติเมตร คิดเป็นกี่ลิตร", a: ["5 ลิตร", "0.5 ลิตร", "0.05 ลิตร", "50 ลิตร"], c: 1, e: "500 ÷ 1000 = 0.5" },
    { q: "กล่องทรงสี่เหลี่ยมจัตุรัสยาวด้านละ 5 cm ปริมาตรเท่าใด", a: ["25 cm³", "125 cm³", "150 cm³", "15 cm³"], c: 1, e: "5 × 5 × 5 = 125" }
];

const area = document.getElementById('questions-area');
let score = 0;
let answered = 0;

quizData.forEach((item, idx) => {
    const card = document.createElement('div');
    card.className = 'q-card';
    card.innerHTML = `
        <p><b>ข้อที่ ${idx + 1}:</b> ${item.q}</p>
        <div class="options" id="opt-grp-${idx}">
            ${item.a.map((opt, i) => `<button onclick="checkAns(${idx}, ${i})">${opt}</button>`).join('')}
        </div>
        <div class="explain-box" id="explain-${idx}"><b>เฉลย:</b> ${item.a[item.c]}<br><b>วิธีคิด:</b> ${item.e}</div>
    `;
    area.appendChild(card);
});

function checkAns(qIdx, cIdx) {
    const grp = document.getElementById(`opt-grp-${qIdx}`);
    if(grp.classList.contains('disabled')) return;
    const btns = grp.getElementsByTagName('button');
    if(cIdx === quizData[qIdx].c) {
        btns[cIdx].classList.add('correct');
        score++;
    } else {
        btns[cIdx].classList.add('wrong');
        btns[quizData[qIdx].c].classList.add('correct');
    }
    grp.classList.add('disabled');
    document.getElementById(`explain-${qIdx}`).style.display = 'block';
    answered++;
}

function finishQuiz() {
    if(answered < 60) { alert("ทำให้ครบ 60 ข้อก่อนนะจ๊ะเด็กๆ!"); return; }
    document.getElementById('quiz-main').style.display = 'none';
    document.getElementById('final-page').style.display = 'block';
    document.getElementById('user-score').innerText = score + "/60";
    
    let report = "<h3>📢 วิเคราะห์จุดอ่อนรายบุคคล:</h3>";
    if(score >= 55) report += "<p>🌟 <b>ยอดเยี่ยม!</b> น้องพร้อมสอบเข้า ม.1 โรงเรียนดังได้เลยครับ แม่นทุกบท!</p>";
    else if(score >= 40) report += "<p>👍 <b>เก่งมาก!</b> มีพลาดบ้างเรื่องการคำนวณเลขเร็ว ลองเช็คข้อที่ผิดดูว่าพลาดเรื่องร้อยละหรือปริมาตรนะครับ</p>";
    else if(score >= 30) report += "<p>📖 <b>พอใช้ได้!</b> น้องต้องระวังเรื่อง 'หน่วย' และ 'สูตรพื้นที่สี่เหลี่ยม' บางชนิดที่ยังจำสับสนนะครับ</p>";
    else report += "<p>💪 <b>สู้ๆ นะ!</b> พี่แนะนำให้กลับไปท่องสูตรพื้นที่สี่เหลี่ยมและฝึกคูณเลขให้แม่นกว่านี้ พี่เป็นกำลังใจให้!</p>";
    document.getElementById('analysis').innerHTML = report;
    window.scrollTo(0,0);
}
</script>

