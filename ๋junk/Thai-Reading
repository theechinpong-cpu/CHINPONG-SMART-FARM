<body>

<div class="container">
    <h1>📚 คลังข้อมูลดิบและข้อสอบ: ศิลปะและการจัดการสัมภาษณ์</h1>

    <div class="summary-box">
        <h2>📑 สรุปเนื้อหาบทเรียน (มากกว่า 400 คำ)</h2>
        <p>การสัมภาษณ์งานคือกระบวนการสื่อสารสองทางที่มีวัตถุประสงค์ชัดเจน เพื่อคัดเลือกบุคคลที่เหมาะสมที่สุดเข้าสู่องค์กร โดยเนื้อหาครอบคลุมตั้งแต่ศิลปะการพูดของผู้สมัคร ไปจนถึงจรรยาบรรณและกระบวนการตัดสินของคณะกรรมการ</p>
        <p><b>ด้านผู้สมัคร:</b> หัวใจสำคัญคือ "การเป็นตัวของตัวเอง" การพยายามตอบคำถามให้ถูกใจผู้สัมภาษณ์มักทำให้เกิดความประหม่าและขาดเสน่ห์ ผู้สมัครควรควบคุมน้ำเสียงให้ดังชัดเจน จังหวะการพูดที่สม่ำเสมอ และหลีกเลี่ยงคำฟุ่มเฟือย (เอ้อ, อ้า) สำหรับผู้ที่มีจุดด้อย เช่น ประสบการณ์น้อย หรือผลการเรียนต่ำ เทคนิคสำคัญคือการดึง "กิจกรรม" หรือ "ทักษะที่ถ่ายโอนได้" มาทดแทน เช่น การทำงานส่งทันกำหนด (Deadline) หรือการทำรายงานชิ้นสำคัญ ซึ่งสะท้อนความรับผิดชอบไม่ต่างจากการทำงานจริง</p>
        <p><b>ด้านผู้สัมภาษณ์และองค์กร:</b> การสัมภาษณ์มีองค์ประกอบ 3 อย่าง คือ เนื้อหา ผู้สัมภาษณ์ และผู้ถูกสัมภาษณ์ โดยมีวัตถุประสงค์เพื่อคาดคะเนและกำหนดพฤติกรรม ตลอดจนแลกเปลี่ยนข้อมูลเชิงลึกที่หาไม่ได้จากใบสมัคร กระบวนการประกอบด้วยการเตรียมการ (จัดสถานที่และสภาพแวดล้อมทางจิตใจ) การดำเนินการ (แนะนำตัว สร้างความสัมพันธ์) และการประเมินผล</p>
        <p><b>การตัดสินและจรรยาบรรณ:</b> วิธีการประเมินผลมีหลายรูปแบบ ตั้งแต่การใช้ความเห็นส่วนตัว การรวมคะแนน การตัดสินแบบ "ได้-ตก" (Must-have criteria) ไปจนถึงการใช้ "ฉันทามติ" (Consensus) ของคณะกรรมการเพื่อลดอคติ (Personal Bias) นอกจากนี้ ผู้สัมภาษณ์ต้องยึดถือจรรยาบรรณ 3 ประการ คือ การรักษาความลับ ความเป็นกลาง และการให้เกียรติผู้สมัคร เพื่อสร้าง Employer Branding ที่ดีให้กับองค์กร แม้ผู้สมัครจะไม่ได้รับการคัดเลือกก็ตาม</p>
    </div>

    <div class="memory-trick">
        <h2>💡 Memory Tricks & Thought Process</h2>
        <ul>
            <li><b>TRICK - "3ป. ของผู้สมัคร":</b> <b>ป</b>กติ (เป็นตัวเอง), <b>ป</b>ระสิทธิภาพ (เสียงชัด/จังหวะดี), <b>ป</b>ิดจุดด้อย (ใช้กิจกรรมแทนเกรด)</li>
            <li><b>TRICK - "5 ประเภทรสสัมผัส":</b> อิสระ (Free), แบบแผน (Structured), มาตรฐาน (Standard), ปัญหา (Problem), สุ่ม (Random)</li>
            <li><b>THOUGHT PROCESS:</b> เมื่อเจอปมด้อย -> ยอมรับความจริง -> เชื่อมโยงสู่ทักษะอื่น -> สรุปเป็นข้อดี (เช่น อายุน้อย = เรียนรู้งานไว + ไอเดียใหม่)</li>
        </ul>
    </div>

    <hr>

    <div id="exam-section">
        <h2>📝 ข้อสอบปรนัย 50 ข้อ (คัดลอกจากข้อมูลดิบ 15 หน้า)</h2>
        <div id="quiz-container"></div>
        <button onclick="checkAnswers()">ส่งคำตอบและดูวิเคราะห์ผล</button>
    </div>

    <div id="result-area">
        <h2>📊 ผลคะแนนของคุณ: <span id="score-display"></span> / 50</h2>
        <p id="analysis-text"></p>
        <button onclick="location.reload()" style="background: #e74c3c; margin-top: 20px;">ทำข้อสอบใหม่อีกครั้ง</button>
    </div>
</div>

<script>
const questions = [
    { q: "หัวใจสำคัญที่สุดของการสัมภาษณ์คืออะไร?", a: ["การตอบให้ถูกใจกรรมการ", "การเป็นตัวของตัวเอง", "การพูดให้มากที่สุด", "การแต่งกายราคาแพง"], c: 1, e: "หน้า 1 ระบุว่าการเป็นตัวของตัวเองสำคัญที่สุด เพราะการพยายามตอบให้ถูกจะทำให้เครียดและผู้สัมภาษณ์จะหมดความสนใจ" },
    { q: "ระดับน้ำเสียงที่เหมาะสมในการสัมภาษณ์คือ?", a: ["เบาเหมือนกระซิบ", "ดังตะโกนให้ได้ยินทั่วห้อง", "ดังพอประมาณให้ได้ยินชัดเจน", "อู้อี้อยู่ในลำคอ"], c: 2, e: "หน้า 1 แนะนำว่าความดังควรอยู่ในระดับที่ได้ยินชัดว่าพูดอะไรก็เพียงพอแล้ว" },
    { q: "คำว่า 'เอ้อ, อ้า, แบบว่า' จัดเป็นคำประเภทใดที่ควรระวัง?", a: ["คำแสลง", "คำเชื่อมสุภาพ", "คำซ้ำคำเกิน", "คำศัพท์เฉพาะทาง"], c: 2, e: "หน้า 1 ระบุว่าคำเหล่านี้ทำให้ผู้ฟังเบื่อรำคาญและควรฝึกฝนเพื่อตัดออก" },
    { q: "หากผู้สมัครพูดอธิบายมากเกินไปในเรื่องที่ควรตอบสั้นๆ จะถูกมองอย่างไร?", a: ["เป็นคนรอบรู้", "เป็นคนขยันทำงาน", "จะเสียเวลาทำงานไปกับการพูด", "เป็นคนมีเสน่ห์"], c: 2, e: "หน้า 1 กล่าวว่าอาจถูกมองว่าถ้าเข้ามาทำงานคงจะเสียเวลาไปกับการพูดมากกว่าทำงาน" },
    { q: "หากถูกจับได้ว่า 'โกหก' ในขณะสัมภาษณ์ จะส่งผลอย่างไร?", a: ["แสดงถึงไหวพริบ", "ไม่มีใครไว้วางใจให้ทำงาน", "ดูเป็นคนมีความพยายาม", "ทำให้ดูเป็นมืออาชีพ"], c: 1, e: "หน้า 2 ระบุว่าถ้ายังไม่เข้าทำงานยังหลอกกันแล้ว จะไม่มีใครไว้วางใจให้ทำงาน" },
    { q: "วิธีแก้จุดด้อยสำหรับผู้สมัครที่มี 'ประสบการณ์น้อย' คือ?", a: ["ยอมรับว่าทำไม่ได้", "อ้างถึงงานพิเศษหรือกิจกรรมสมัยเรียน", "เงียบไม่ตอบ", "โกหกว่าเคยทำ"], c: 1, e: "หน้า 2 แนะนำให้อ้างถึงงานพิเศษหรืองานกิจกรรมมหาวิทยาลัยที่จำเป็นต่องาน" },
    { q: "ผู้สมัครที่ 'เรียนอย่างเดียว' ควรนำเสนอจุดเด่นอย่างไร?", a: ["บอกว่าไม่มีประสบการณ์", "อ้างถึงการทำงานส่งทันกำหนดเส้นตาย", "บอกว่าไม่ชอบกิจกรรม", "อ้างว่าเกรดสูงก็พอแล้ว"], c: 1, e: "หน้า 2 แนะนำให้ใช้การเรียนเป็นประสบการณ์ เช่น การส่งงานตรงเวลา (Deadline)" },
    { q: "ในกรณี GPA ต่ำ ผู้สมัครควรเน้นย้ำเรื่องใด?", a: ["เกรดไม่ใช่สิ่งสำคัญ", "เน้นประสบการณ์ชีวิตจริงหรือกิจกรรม", "ขอความเห็นใจ", "บอกว่าอาจารย์ให้คะแนนยาก"], c: 1, e: "หน้า 2 ให้เน้นว่าความสำเร็จในการทำงานต้องการสิ่งอื่นมากกว่าแค่เกรดสูง" },
    { q: "ข้อใดคือข้อดีของ 'ผู้สมัครอายุน้อย'?", a: ["มีไอเดียทันสมัยและเรียนรู้สิ่งใหม่", "ต้องการสวัสดิการมาก", "มีความเป็นผู้นำสูงกว่า", "มีนิสัยการทำงานเก่าๆ ที่ดี"], c: 0, e: "หน้า 2 ระบุข้อดีของอายุน้อยคือไอเดียทันสมัยและไม่ต้องแก้นิสัยการทำงานเก่าๆ" },
    { q: "ความหมายของการสัมภาษณ์คืออะไร?", a: ["การพูดฝ่ายเดียว", "การสนทนาที่มีวัตถุประสงค์", "การทะเลาะวิวาท", "การเล่นเกมจิตวิทยา"], c: 1, e: "หน้า 3 ระบุว่าการสัมภาษณ์คือการสนทนาที่มีวัตถุประสงค์เพื่อคัดเลือกคนเข้าทำงาน" },
    { q: "องค์ประกอบของการสัมภาษณ์มีกี่อย่าง?", a: ["2 อย่าง", "3 อย่าง", "4 อย่าง", "5 อย่าง"], c: 1, e: "หน้า 3 ระบุว่ามี 3 อย่างคือ เนื้อหา, ผู้สัมภาษณ์ และผู้ถูกสัมภาษณ์" },
    { q: "วัตถุประสงค์ทั่วไปของการสัมภาษณ์คือข้อใด?", a: ["เพื่อหาข้อมูลการศึกษา", "เพื่อคาดคะเนพฤติกรรมของบุคคล", "เพื่อหาที่พักให้ผู้สมัคร", "เพื่อตรวจสอบประวัติอาชญากรรม"], c: 1, e: "หน้า 4 ระบุวัตถุประสงค์ทั่วไปคือ คาดคะเน, เปลี่ยน และกำหนดพฤติกรรม" },
    { q: "การให้ข้อมูลเกี่ยวกับ 'สวัสดิการ' จัดเป็นวัตถุประสงค์แบบใด?", a: ["วัตถุประสงค์ทั่วไป", "วัตถุประสงค์เฉพาะ", "วัตถุประสงค์แฝง", "วัตถุประสงค์ทางอ้อม"], c: 1, e: "หน้า 4 การให้ข้อมูลหน่วยงานและสวัสดิการเป็นวัตถุประสงค์เฉพาะ" },
    { q: "ประโยชน์ของการสัมภาษณ์ต่อ 'หน่วยงาน' คืออะไร?", a: ["ทำให้ผู้สมัครได้เพื่อนใหม่", "ประหยัดค่าเอกสาร", "เข้าถึงทักษะการสื่อสารที่ดูจากประวัติไม่ได้", "ช่วยในการโฆษณาสินค้า"], c: 2, e: "หน้า 5 ระบุว่าทำให้เห็นทักษะการสื่อสารที่วิเคราะห์ไม่ได้จากประวัติหรือแบบสอบถาม" },
    { q: "ประเภทการสัมภาษณ์ที่มีการเตรียมคำถามไว้ล่วงหน้าคือ?", a: ["แบบสุ่ม", "แบบอิสระ", "แบบมีแบบแผน", "แบบไม่มีโครงสร้าง"], c: 2, e: "หน้า 6 การสัมภาษณ์แบบมีแบบแผน (Structured) จะมีการเตรียมการไว้" },
    { q: "สิ่งใดมีอิทธิพลต่อการตัดสินใจของผู้สัมภาษณ์?", a: ["อากาศในห้อง", "การเรียงลำดับข้อมูลที่ได้", "ยี่ห้อรถของผู้สมัคร", "จำนวนหน้าของใบสมัคร"], c: 1, e: "หน้า 6 ระบุว่าการเรียงลำดับข้อมูลเป็นองค์ประกอบหนึ่งที่มีอิทธิพลต่อการตัดสินใจ" },
    { q: "แบบสัมภาษณ์โดยทั่วไปต้องมีข้อมูลด้านใด?", a: ["ชื่อสัตว์เลี้ยง", "ประวัติการทำงาน", "อาหารที่ชอบ", "สถานที่ท่องเที่ยวที่เคยไป"], c: 1, e: "หน้า 7 ระบุ 4 ด้านสำคัญ: งาน, การศึกษา, ครอบครัว, การปรับตัวทางสังคม" },
    { q: "การจัดห้องสัมภาษณ์ให้สงบและอากาศถ่ายเทสะดวกคือสภาพแวดล้อมชนิดใด?", a: ["ทางจิตใจ", "ทางสังคม", "ทางวัตถุ", "ทางอารมณ์"], c: 2, e: "หน้า 7 ห้องและอุปกรณ์ต่างๆ จัดเป็นสภาพแวดล้อมทางวัตถุ" },
    { q: "สภาพแวดล้อมทางจิตใจที่ดีควรเป็นอย่างไร?", a: ["กดดันเพื่อให้เห็นตัวตน", "บรรยากาศผ่อนคลาย ไม่กดดัน", "เงียบสนิทจนน่ากลัว", "มีการเปิดเพลงเสียงดัง"], c: 1, e: "หน้า 7 บรรยากาศผ่อนคลายช่วยให้ผู้สมัครกล้าให้ข้อมูลที่แท้จริง" },
