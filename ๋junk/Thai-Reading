        h1, h2, h3 { color: #2c3e50; border-bottom: 2px solid #3498db; padding-bottom: 10px; }
        .raw-content { background: #fffdf0; border-left: 5px solid #f1c40f; padding: 20px; margin-bottom: 30px; }
        .summary-box { background: #e8f4fd; border-left: 5px solid #3498db; padding: 20px; margin-bottom: 30px; }
        .memory-trick { background: #eafaf1; border-left: 5px solid #2ecc71; padding: 20px; margin-bottom: 30px; }
        .question-block { margin-bottom: 25px; padding: 20px; border: 1px solid #ddd; border-radius: 8px; transition: 0.3s; }
        .question-block:hover { background: #f9f9f9; border-color: #3498db; }
        .options label { display: block; margin: 10px 0; cursor: pointer; }
        .explanation { display: none; background: #fff3cd; padding: 15px; border-radius: 5px; margin-top: 10px; font-weight: bold; }
        .correct { color: #27ae60; }
        .incorrect { color: #e74c3c; }
