function loadQuiz() {
    const container = document.getElementById('quiz-container');
    questions.forEach((item, index) => {
        const block = document.createElement('div');
        block.className = 'question-block';
        block.innerHTML = `
            <p><strong>ข้อที่ ${index + 1}:</strong> ${item.q}</p>
            <div class="options">
                ${item.a.map((opt, i) => `
                    <label>
                        <input type="radio" name="q${index}" value="${i}"> ${opt}
                    </label>
                `).join('')}
            </div>
            <div id="exp${index}" class="explanation"></div>
        `;
        container.appendChild(block);
    });
}

function checkAnswers() {
    let score = 0;
    questions.forEach((item, index) => {
        const selected = document.querySelector(`input[name="q${index}"]:checked`);
        const expBox = document.getElementById(`exp${index}`);
        expBox.style.display = 'block';
        
        if (selected) {
            if (parseInt(selected.value) === item.c) {
                score++;
                expBox.innerHTML = `<span class="correct">ถูกต้อง!</span> ${item.e}`;
            } else {
                expBox.innerHTML = `<span class="incorrect">ผิด! (คำตอบที่ถูกคือ: ${item.a[item.c]})</span><br>${item.e}`;
            }
        } else {
            expBox.innerHTML = `<span class="incorrect">ไม่ได้ตอบ! (คำตอบที่ถูกคือ: ${item.a[item.c]})</span><br>${item.e}`;
        }
    });

    document.getElementById('exam-section').style.display = 'none';
    document.getElementById('result-area').style.display = 'block';
    document.getElementById('score-display').innerText = score;
    
    let analysis = "";
    if (score >= 45) analysis = "ยอดเยี่ยมมาก! คุณมีความเข้าใจลึกซึ้งทั้งในมุมผู้สมัครและผู้สัมภาษณ์";
    else if (score >= 35) analysis = "เกณฑ์ดี! คุณเข้าใจหลักการส่วนใหญ่ แต่อาจต้องทบทวนเรื่องจรรยาบรรณหรือเทคนิคเฉพาะทางเพิ่มเติม";
    else if (score >= 25) analysis = "ผ่านเกณฑ์ขั้นต่ำ! คุณยังสับสนในเรื่องของกระบวนการตัดสินและอคติในการสัมภาษณ์";
    else analysis = "ควรทบทวนใหม่! คุณยังขาดความเข้าใจในเรื่องศิลปะการสื่อสารและขั้นตอนมาตรฐานของการสัมภาษณ์";
    
    document.getElementById('analysis-text').innerText = analysis;
    window.scrollTo(0, 0);
}

loadQuiz();
</script>

