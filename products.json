def generate_smart_keywords(name):
    # กำหนด "Stop Words" หรือคำที่ไม่ควรเอามาทำเป็น Keyword เพื่อความแม่นยำ
    ignore_words = {"ส่งฟรี", "ลูกค้าใหม่", "ของเเถม", "พร้อมส่ง", "จัดส่ง", "รุ่น", "แบบ", "สไตล์", "คุณภาพ"}
    # คัดเฉพาะภาษาไทยและอังกฤษ
    clean_name = re.sub(r'[^\u0e00-\u0e7fa-zA-Z0-9\s]', ' ', name)
    words = clean_name.split()
    
    keywords = []
    for w in words:
        if len(w) > 2 and w not in ignore_words:
            keywords.append(w)
    
    # ส่งคืนแค่ 5 คำหลักที่สั้นและกระชับที่สุด
    return list(dict.fromkeys(keywords))[:5]

def process_data(raw_text):
    products_list = []
    f = io.StringIO(raw_text.strip())
    
    for line in f:
        cols = line.split('\t')
        if len(cols) >= 9:
            # ทำความสะอาดราคา (เผื่อมีคำว่า พัน หรือ ฿)
            price = cols[2].strip().replace('฿', '')
            
            product = {
                "id": cols[0].strip(),
                "name": cols[1].strip(),
                "price": price,
                "shop": cols[4].strip(),
                "commission": cols[5].strip(),
                "affLink": cols[8].strip(), # ใช้ลิงก์ข้อเสนอสั้นๆ
                "keywords": generate_smart_keywords(cols[1].strip())
            }
            products_list.append(product)
    
    return products_list

# รันประมวลผล
all_products = process_data(raw_data_input)

# บันทึกไฟล์
with open('products.json', 'w', encoding='utf-8') as f:
    json.dump(all_products, f, ensure_ascii=False, indent=4)

print(f"🚀 เรียบร้อย! ประมวลผลสินค้าทั้งหมด {len(all_products)} รายการลงใน products.json แล้ว")
